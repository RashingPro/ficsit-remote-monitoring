{
  "name": "ficsit-remote-monitoring",
  "version": "2.0.0",
  "description": "Node.js interface for Satisfactory via Ficsit Remote Monitoring mod",
  "author": {
    "name": "RashingPro",
    "url": "https://rashing.pro/",
    "email": "contact@rashing.pro"
  },
  "keywords": [
    "typescript",
    "api",
    "interface",
    "satisfactory",
    "ficsit",
    "mod"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RashingPro/ficsit-remote-monitoring.git"
  },
  "license": "MIT",
  "scripts": {
    "format": "prettier . --write",
    "lint": "eslint . --fix",
    "cleanOutDir": "rimraf dist",
    "prebuild": "npm run format && npm run lint",
    "build": "npm run cleanOutDir && rollup --config rollup.config.ts --configPlugin typescript",
    "knip": "knip",
    "test": "jest",
    "postinstall": "husky"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "package.json",
    "dist",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@commitlint/format": "^21.0.1",
    "@commitlint/types": "^21.0.1",
    "@eslint/js": "^9.39.4",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.8.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jiti": "^2.7.0",
    "knip": "^6.14.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.4",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-dts-minify": "^1.0.1",
    "ts-jest": "^29.4.9",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3"
  }
}
